# Copy this file to .env and fill in the values.
#
# BINANCE_API_KEY and BINANCE_SECRET_KEY can be obtained from:
#   - Live trading: https://www.binance.com/en/my/settings/api-management
#   - Testnet:      https://testnet.binance.vision
#
# BINANCE_TESTNET: set to true to use testnet, false for live trading.

export BINANCE_API_KEY=
export BINANCE_SECRET_KEY=
export BINANCE_TESTNET=true
export DATABASE_URL=postgres://postgers:postgers@localhost:5432/cm3
